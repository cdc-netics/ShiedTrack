# =============================================================================
# ShieldTrack - Docker Compose (raiz del repositorio)
# =============================================================================
# 1) Copiar este archivo:  copy .env.example .env   (PowerShell)
# 2) Cambiar JWT_SECRET y revisar puertos / CORS.
# 3) docker compose up --build -d
#
# Compose lee automaticamente .env junto a docker-compose.yml.
# No subas .env al Git (esta en .gitignore).
#
# Credenciales de login de prueba (NO se configuran aqui):
#   docs/DEVELOPMENT-CREDENTIALS.md
# =============================================================================

# --- Puertos en TU maquina (host). Cambiar solo aqui si hay conflicto ---
MONGO_PORT=27017
BACKEND_PORT=3000
FRONTEND_PORT=80

# --- URLs que abriras en el navegador (referencia; dependen de FRONTEND_PORT / BACKEND_PORT) ---
# App web (Angular tras nginx):  http://localhost   (puerto 80 por defecto del navegador)
# Si FRONTEND_PORT=8080:          http://localhost:8080
# API / Swagger:                 http://localhost:BACKEND_PORT/api/docs

# --- Backend (NestJS dentro del contenedor) ---
JWT_SECRET=cambiar-por-cadena-larga-y-aleatoria-en-produccion
JWT_EXPIRES_IN=8h
# Puerto HTTP *dentro* del contenedor backend (debe coincidir con PORT del Dockerfile / Nest)
PORT=3000
# development = CORS mas permisivo al depurar; production en despliegue real
NODE_ENV=development

FRONTEND_URL=http://localhost
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:4200,http://127.0.0.1:4200

# --- MongoDB: usuario y clave (usados por la imagen oficial al crear el volumen) ---
# Deben coincidir con user y password dentro de MONGODB_URI (mismo usuario root del contenedor).
# Si la contrasena tiene caracteres especiales (@ : / ? #), codificala en la URI (RFC 3986).
MONGO_INITDB_ROOT_USERNAME=shieldtrack
MONGO_INITDB_ROOT_PASSWORD=shieldtrack_dev

# URI que usa el backend y los seeds (host "mongodb" = servicio en docker-compose.yml).
MONGODB_URI=mongodb://MONGO_INITDB_ROOT_USERNAME:MONGO_INITDB_ROOT_PASSWORD@mongodb:27017/shieldtrack?authSource=admin

# Si antes tenias Mongo SIN auth en el mismo volumen, el usuario root no se crea solo:
#   docker compose down -v   (borra datos; solo desarrollo)
# Luego: docker compose up --build

# =============================================================================
# Seeds (usuarios admin + datos de prueba) - NO son variables de entorno
# =============================================================================
# Con Docker: al iniciar el contenedor "backend" se ejecutan en orden:
#   npm run seed:owner   -> primer usuario OWNER (admin@shieldtrack.com) si no existe
#   npm run seed:test    -> resto de usuarios P0 y datos de prueba
# Ver logs: docker compose logs backend
#
# Repetir seeds manualmente sin reiniciar el contenedor (desde la raiz del repo):
#   docker compose exec backend npm run seed:owner
#   docker compose exec backend npm run seed:test
#
# Sin Docker (solo backend local): en carpeta backend/
#   npm run seed:owner
#   npm run seed:test
#
# No hace falta repetir npm si solo usas Docker y los seeds ya corrieron bien.
