# =============================================================================
# ShieldTrack - variables para Docker Compose (raiz del repositorio)
# =============================================================================
# Copiar a .env:
#   copy .env.example .env    (Windows PowerShell)
#   cp .env.example .env      (Linux/macOS)
#
# Docker Compose lee el archivo .env de esta carpeta para sustituir variables
# en docker-compose.yml. No subas .env al repositorio (esta en .gitignore).
#
# Usuarios de prueba: docs/DEVELOPMENT-CREDENTIALS.md
# =============================================================================

# Puertos publicados en el host (opcional)
# MONGO_PORT=27017
# BACKEND_PORT=3000
# FRONTEND_PORT=80

# --- API (backend en contenedor) ---
JWT_SECRET=cambiar-por-cadena-larga-y-aleatoria-en-produccion
JWT_EXPIRES_IN=8h
PORT=3000
NODE_ENV=production

# Origen/es del navegador (front en Docker: http://localhost si usa puerto 80)
FRONTEND_URL=http://localhost
CORS_ORIGINS=http://localhost,http://127.0.0.1

# --- MongoDB ---
# Por defecto el servicio Mongo en Compose NO usa usuario ni contrasena
# (solo razonable en desarrollo local). En produccion use Atlas o active auth.
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# URI que usa NestJS (hostname del servicio en Compose: mongodb)
MONGODB_URI=mongodb://mongodb:27017/shieldtrack

# Si activa usuario root arriba, descomente y ajuste authSource:
# MONGODB_URI=mongodb://root:TU_CLAVE@mongodb:27017/shieldtrack?authSource=admin
