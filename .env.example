# ShieldTrack - plantilla de entorno (copiar a .env y NO subir .env a Git)
# 1) copy .env.example .env   (PowerShell)
# 2) Cambiar JWT_SECRET.
# 3) docker compose up --build -d
# Login de prueba: docs/DEVELOPMENT-CREDENTIALS.md

# --- Puertos en el host (cambiar si 27017 / 3000 / 80 estan ocupados) ---
MONGO_PORT=27017
BACKEND_PORT=3000
FRONTEND_PORT=80

# URLs en el navegador (dependen de FRONTEND_PORT / BACKEND_PORT):
# App: http://localhost  (o http://localhost:FRONTEND_PORT si no es 80)
# API / Swagger: http://localhost:BACKEND_PORT/api/docs

# --- Backend ---
JWT_SECRET=cambiar-por-cadena-larga-y-aleatoria-en-produccion
JWT_EXPIRES_IN=8h
PORT=3000
NODE_ENV=development

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=shieldtrack
MONGO_INITDB_ROOT_PASSWORD=shieldtrack_dev

# FRONTEND_URL, CORS_ORIGINS y MONGODB_URI se construyen en docker-compose.yml
# a partir de las variables anteriores. No repetir valores aqui.

# Si antes tenias Mongo SIN auth en el mismo volumen, el usuario root no se crea solo:
#   docker compose down -v   (borra datos; solo desarrollo)
# Luego: docker compose up --build

# =============================================================================
# Seeds (usuarios admin + datos de prueba) - NO son variables de entorno
# =============================================================================
# Con Docker: al iniciar el contenedor "backend" se ejecutan en orden:
#   npm run seed:owner   -> primer usuario OWNER (admin@shieldtrack.com) si no existe
#   npm run seed:test    -> resto de usuarios P0 y datos de prueba
# Ver logs: docker compose logs backend
#
# Repetir seeds manualmente sin reiniciar el contenedor (desde la raiz del repo):
#   docker compose exec backend npm run seed:owner
#   docker compose exec backend npm run seed:test
#
# Sin Docker (solo backend local): en carpeta backend/
#   npm run seed:owner
#   npm run seed:test
#
# No hace falta repetir npm si solo usas Docker y los seeds ya corrieron bien.
