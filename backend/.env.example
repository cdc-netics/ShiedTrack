# MongoDB
MONGODB_URI=mongodb://localhost:27017/shieldtrack

# JWT
JWT_SECRET=shieldtrack-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# Application
PORT=3000
FRONTEND_URL=http://localhost:4200

# CORS: origenes permitidos (coma-separados). Si esta vacio, en desarrollo se permite sin header Origin; en produccion debe coincidir con el origen del navegador.
# Ejemplo: CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CORS_ORIGINS=http://localhost:4200

# NODE_ENV=production activa politicas mas estrictas (p. ej. CORS sin Origin solo si no aplica)
# NODE_ENV=development

# SMTP para notificaciones de retest
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@shieldtrack.com

# Almacenamiento de evidencias
EVIDENCE_STORAGE_PATH=./uploads/evidence
